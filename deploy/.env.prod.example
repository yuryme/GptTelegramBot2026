APP_NAME=Telegram AI Reminder Bot
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
TELEGRAM_DELIVERY_MODE=polling
TELEGRAM_POLLING_DROP_PENDING_UPDATES=true

LLM_PROVIDER=deepseek
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20.0
LLM_MAX_ATTEMPTS=1
STT_PROVIDER=openai
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
STT_HTTP_URL=http://127.0.0.1:18100/transcribe
STT_HTTP_TIMEOUT_SECONDS=120.0
GROQ_API_KEY=replace_me
GROQ_STT_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_LANGUAGE=ru
GROQ_STT_TIMEOUT_SECONDS=120.0
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
OPENAI_MONTHLY_BUDGET_USD=10.0
OPENAI_ESTIMATED_INPUT_COST_PER_1K=0.0003
OPENAI_ESTIMATED_OUTPUT_COST_PER_1K=0.0012

POSTGRES_DB=reminder_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql+psycopg://postgres:replace_me@db:5432/reminder_bot

DOMAIN=bot.example.com
LETSENCRYPT_EMAIL=admin@example.com
